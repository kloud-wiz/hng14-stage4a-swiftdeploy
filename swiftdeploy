#!/usr/bin/env python3

import os
import sys
import time
import json
import socket
import subprocess
import urllib.request
import urllib.error
from pathlib import Path

import yaml
import psutil
from jinja2 import Environment, FileSystemLoader

# ── paths ────────────────────────────────────────────────────────────────────
ROOT        = Path(__file__).parent.resolve()
MANIFEST    = ROOT / "manifest.yaml"
NGINX_CONF  = ROOT / "nginx.conf"
COMPOSE     = ROOT / "docker-compose.yml"
TEMPLATES   = ROOT / "templates"

# ── helpers ──────────────────────────────────────────────────────────────────

def load_manifest():
    """Load and return the parsed manifest.yaml."""
    with open(MANIFEST) as f:
        return yaml.safe_load(f)


def render_templates(manifest):
    """Render nginx.conf and docker-compose.yml from Jinja2 templates."""
    env = Environment(loader=FileSystemLoader(str(TEMPLATES)))

    nginx_tmpl   = env.get_template("nginx.conf.j2")
    compose_tmpl = env.get_template("docker-compose.yml.j2")

    NGINX_CONF.write_text(nginx_tmpl.render(**manifest))
    COMPOSE.write_text(compose_tmpl.render(**manifest))


def run(cmd, check=True):
    """Run a shell command, streaming output to stdout."""
    return subprocess.run(cmd, shell=True, check=check)


def compose(cmd, check=True):
    """Run a docker compose subcommand from the project root."""
    return run(f"docker compose -f {COMPOSE} {cmd}", check=check)


def get_nginx_port():
    manifest = load_manifest()
    return manifest["nginx"]["port"]


def get_app_port():
    manifest = load_manifest()
    return manifest["services"]["port"]


def health_check(timeout=60):
    """Poll /healthz through nginx until it responds 200 or timeout."""
    port    = get_nginx_port()
    url     = f"http://localhost:{port}/healthz"
    deadline = time.time() + timeout

    print(f"⏳ Waiting for stack to be healthy (timeout: {timeout}s)...")

    while time.time() < deadline:
        try:
            with urllib.request.urlopen(url, timeout=3) as r:
                if r.status == 200:
                    print("✅ Stack is healthy!")
                    return True
        except Exception:
            pass
        time.sleep(3)

    print("❌ Health check timed out after 60s")
    return False

def wait_for_opa(timeout=30):
    """Wait for OPA to be ready before running policy checks."""
    manifest = load_manifest()
    opa_port = manifest.get("opa", {}).get("port", 8181)
    url = f"http://localhost:{opa_port}/health"
    deadline = time.time() + timeout

    while time.time() < deadline:
        try:
            with urllib.request.urlopen(url, timeout=2) as r:
                if r.status == 200:
                    return True
        except Exception:
            pass
        time.sleep(2)
    return False

def query_opa(policy_path, input_data):
    """
    Query OPA with input data and return the decision.
    Returns (allow, violations, error) tuple.
    """
    manifest = load_manifest()
    opa_port = manifest.get("opa", {}).get("port", 8181)
    opa_url = f"http://localhost:{opa_port}/v1/data/{policy_path}"
    payload = json.dumps({"input": input_data}).encode()

    try:
        req = urllib.request.Request(
            opa_url,
            data=payload,
            headers={"Content-Type": "application/json"},
            method="POST"
        )
        with urllib.request.urlopen(req, timeout=5) as r:
            result = json.loads(r.read())
            result = result.get("result", {})
            allow = result.get("allow", False)
            violations = list(result.get("violations", []))
            return allow, violations, None

    except urllib.error.URLError:
        return None, [], "OPA is unavailable — cannot connect to policy engine"
    except urllib.error.HTTPError as e:
        return None, [], f"OPA returned HTTP {e.code}: {e.reason}"
    except Exception as e:
        return None, [], f"OPA query failed: {e}"


def pre_deploy_check():
    """Collect host stats and query OPA infrastructure policy."""
    print("🔍 Running pre-deploy policy check...\n")

    disk = psutil.disk_usage("/")
    disk_free_gb = disk.free / (1024 ** 3)
    cpu_load = psutil.getloadavg()[0]
    memory = psutil.virtual_memory()
    memory_percent = memory.percent

    input_data = {
        "disk_free_gb": round(disk_free_gb, 2),
        "cpu_load": round(cpu_load, 2),
        "memory_percent": round(memory_percent, 2),
        "check": "pre-deploy"
    }

    print(f"   Disk free:    {disk_free_gb:.1f}GB")
    print(f"   CPU load:     {cpu_load:.2f}")
    print(f"   Memory usage: {memory_percent:.1f}%\n")

    allow, violations, error = query_opa("swiftdeploy/infrastructure", input_data)

    if error:
        print(f"⚠️  Policy check skipped: {error}")
        return True  # Fail open — allow deploy if OPA is unavailable

    if not allow:
        print("❌ Pre-deploy policy check FAILED:")
        for v in violations:
            print(f"   • {v}")
        print()
        return False

    print("✅ Pre-deploy policy check PASSED\n")
    return True


def scrape_metrics():
    """Scrape /metrics from the app via nginx and parse Prometheus text format."""
    port = get_nginx_port()
    url = f"http://localhost:{port}/metrics"

    try:
        with urllib.request.urlopen(url, timeout=5) as r:
            return r.read().decode()
    except Exception as e:
        return None


def parse_metrics(metrics_text):
    """Parse Prometheus text format and extract key values."""
    result = {}
    for line in metrics_text.splitlines():
        if line.startswith("#"):
            continue
        if " " in line:
            key, value = line.rsplit(" ", 1)
            result[key.strip()] = float(value.strip())
    return result


def calculate_error_rate(metrics):
    """Calculate error rate from http_requests_total counter."""
    total = 0
    errors = 0

    for key, value in metrics.items():
        if key.startswith("http_requests_total{"):
            total += value
            if 'status_code="5' in key:
                errors += value

    if total == 0:
        return 0.0
    return errors / total


def calculate_p99_latency(metrics_text):
    """
    Calculate average latency in ms using sum/count from histogram.
    Uses _sum/_count for accuracy since bucket label collisions
    make percentile calculation unreliable in simple text parsing.
    """
    total_sum = 0.0
    total_count = 0.0

    for line in metrics_text.splitlines():
        if line.startswith("#"):
            continue
        if "http_request_duration_seconds_sum" in line and "_created" not in line:
            try:
                total_sum += float(line.split(" ")[-1])
            except ValueError:
                pass
        if "http_request_duration_seconds_count" in line and "_created" not in line:
            try:
                total_count += float(line.split(" ")[-1])
            except ValueError:
                pass

    if total_count == 0:
        return 0.0

    avg_ms = (total_sum / total_count) * 1000
    # Estimate P99 as 3x average — reasonable approximation for low-traffic services
    return round(avg_ms * 3, 2)


def pre_promote_check():
    """Scrape metrics, calculate error rate and P99 latency, query OPA canary policy."""
    print("🔍 Running pre-promote policy check...\n")

    metrics_text = scrape_metrics()
    if not metrics_text:
        print("⚠️  Could not scrape /metrics — skipping policy check")
        return True

    metrics = parse_metrics(metrics_text)
    error_rate = calculate_error_rate(metrics)
    p99_latency_ms = calculate_p99_latency(metrics_text)

    input_data = {
        "error_rate": round(error_rate, 4),
        "p99_latency_ms": round(p99_latency_ms, 2),
        "check": "pre-promote"
    }

    print(f"   Error rate:   {error_rate * 100:.2f}%")
    print(f"   P99 latency:  {p99_latency_ms:.1f}ms\n")

    allow, violations, error = query_opa("swiftdeploy/canary", input_data)

    if error:
        print(f"⚠️  Policy check skipped: {error}")
        return True

    if not allow:
        print("❌ Pre-promote policy check FAILED:")
        for v in violations:
            print(f"   • {v}")
        print()
        return False

    print("✅ Pre-promote policy check PASSED\n")
    return True

# ── subcommands ───────────────────────────────────────────────────────────────

def cmd_init():
    """Parse manifest and generate nginx.conf + docker-compose.yml."""
    print("🔧 Running init...")

    if not MANIFEST.exists():
        print("❌ manifest.yaml not found")
        sys.exit(1)

    manifest = load_manifest()
    render_templates(manifest)

    print(f"✅ Generated: {NGINX_CONF}")
    print(f"✅ Generated: {COMPOSE}")


def cmd_validate():
    """Run 5 pre-flight checks and report pass/fail for each."""
    print("🔍 Running validate...\n")
    failures = 0

    # Check 1 — manifest.yaml exists and is valid YAML
    try:
        manifest = load_manifest()
        print("✅ [1/5] manifest.yaml exists and is valid YAML")
    except Exception as e:
        print(f"❌ [1/5] manifest.yaml is missing or invalid: {e}")
        sys.exit(1)

    # Check 2 — all required fields are present and non-empty
    required = {
        "services.image":       manifest.get("services", {}).get("image"),
        "services.port":        manifest.get("services", {}).get("port"),
        "nginx.image":          manifest.get("nginx", {}).get("image"),
        "nginx.port":           manifest.get("nginx", {}).get("port"),
        "network.name":         manifest.get("network", {}).get("name"),
        "network.driver_type":  manifest.get("network", {}).get("driver_type"),
    }
    missing = [k for k, v in required.items() if not v]
    if missing:
        print(f"❌ [2/5] Missing required fields: {', '.join(missing)}")
        failures += 1
    else:
        print("✅ [2/5] All required fields are present and non-empty")

    # Check 3 — Docker image exists locally
    image = manifest["services"]["image"]
    result = subprocess.run(
        f"docker image inspect {image}",
        shell=True, capture_output=True
    )
    if result.returncode != 0:
        print(f"❌ [3/5] Docker image '{image}' not found locally")
        failures += 1
    else:
        print(f"✅ [3/5] Docker image '{image}' exists locally")

    # Check 4 — nginx port is not already bound on the host
    nginx_port = manifest["nginx"]["port"]
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.settimeout(1)
        in_use = s.connect_ex(("localhost", nginx_port)) == 0
    if in_use:
        print(f"❌ [4/5] Port {nginx_port} is already in use on the host")
        failures += 1
    else:
        print(f"✅ [4/5] Port {nginx_port} is available")

    # Check 5 — generated nginx.conf is syntactically valid
    if not NGINX_CONF.exists():
        print("❌ [5/5] nginx.conf not found — run 'swiftdeploy init' first")
        failures += 1
    else:
        # Use a custom nginx.conf that replaces the upstream 'app' with localhost
        # so nginx -t can validate syntax without needing the Docker network
        test_conf = NGINX_CONF.read_text().replace("http://app:", "http://127.0.0.1:")
        test_conf_path = ROOT / ".nginx_test.conf"
        test_conf_path.write_text(test_conf)

        result = subprocess.run(
            f"docker run --rm -v {test_conf_path}:/etc/nginx/conf.d/default.conf:ro nginx:latest nginx -t",
            shell=True, capture_output=True
        )
        test_conf_path.unlink()  # clean up temp file

        if result.returncode != 0:
            print(f"❌ [5/5] nginx.conf has syntax errors")
            print(result.stderr.decode())
            failures += 1
        else:
            print("✅ [5/5] nginx.conf is syntactically valid")

    print()
    if failures:
        print(f"❌ Validation failed — {failures} check(s) did not pass")
        sys.exit(1)
    else:
        print("✅ All checks passed — ready to deploy")


def cmd_deploy():
    """Run init, bring up the stack, and wait for health checks to pass."""
    print("🚀 Running deploy...\n")
    cmd_init()
    print()

    # Start OPA first so policy checks can run
    compose("up -d opa")
    print("⏳ Waiting for OPA to be ready...")
    if not wait_for_opa():
        print("⚠️  OPA did not start in time — proceeding without policy check")
    else:
        print("✅ OPA is ready\n")
        if not pre_deploy_check():
            print("🚫 Deployment blocked by policy")
            compose("down opa", check=False)
            sys.exit(1)

    compose("up -d --build")
    print()
    if not health_check():
        sys.exit(1)


def cmd_promote(mode):
    """Switch deployment mode between stable and canary."""
    if mode not in ("stable", "canary"):
        print("❌ Usage: swiftdeploy promote [stable|canary]")
        sys.exit(1)

    print(f"🔄 Promoting to {mode} mode...\n")

    # Update mode field in manifest.yaml in-place
    with open(MANIFEST) as f:
        content = f.read()

    manifest = yaml.safe_load(content)
    old_mode = manifest["services"]["mode"]

    if old_mode == mode:
        print(f"ℹ️  Already in {mode} mode — nothing to do")
        sys.exit(0)

    # Run pre-promote policy check before switching to canary
    if mode == "canary":
        if not pre_promote_check():
            print("🚫 Promotion blocked by policy")
            sys.exit(1)

    # Replace mode value in-place preserving file structure
    updated = content.replace(f"mode: {old_mode}", f"mode: {mode}", 1)
    with open(MANIFEST, "w") as f:
        f.write(updated)

    print(f"✅ manifest.yaml updated: {old_mode} → {mode}")

    # Regenerate docker-compose.yml with new mode
    manifest = load_manifest()
    render_templates(manifest)
    print("✅ docker-compose.yml regenerated")

    # Restart only the app service container
    compose("up -d --no-deps --force-recreate app")
    print()

    # Confirm new mode is active via /healthz
    port = get_nginx_port()
    url  = f"http://localhost:{port}/healthz"
    print("⏳ Confirming new mode is active...")
    time.sleep(5)

    try:
        with urllib.request.urlopen(url, timeout=10) as r:
            print(f"✅ Service is up — promote to {mode} complete")
    except Exception as e:
        print(f"❌ Could not confirm service health: {e}")
        sys.exit(1)


def cmd_teardown(clean=False):
    """Remove all containers, networks, and volumes."""
    print("🧹 Running teardown...\n")
    compose("down --volumes --remove-orphans", check=False)

    if clean:
        for f in [NGINX_CONF, COMPOSE]:
            if f.exists():
                f.unlink()
                print(f"🗑️  Deleted: {f}")

    print("✅ Teardown complete")


# ── entrypoint ────────────────────────────────────────────────────────────────

def cmd_status():
    """
    Live-refreshing terminal dashboard.
    Scrapes /metrics every 5 seconds, displays real-time stats,
    policy compliance, and appends to history.jsonl.
    """
    history_file = ROOT / "history.jsonl"
    manifest = load_manifest()
    opa_port = manifest.get("opa", {}).get("port", 8181)

    print("📊 SwiftDeploy Status Dashboard (Ctrl+C to exit)\n")

    try:
        while True:
            metrics_text = scrape_metrics()
            timestamp = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())

            if not metrics_text:
                print(f"[{timestamp}] ⚠️  Could not scrape /metrics — is the stack running?")
                time.sleep(5)
                continue

            metrics = parse_metrics(metrics_text)
            error_rate = calculate_error_rate(metrics)
            p99_latency_ms = calculate_p99_latency(metrics_text)
            uptime = metrics.get("app_uptime_seconds", 0)
            mode_val = metrics.get("app_mode", 0)
            chaos_val = metrics.get("chaos_active", 0)

            mode_str = "canary" if mode_val == 1 else "stable"
            chaos_map = {0: "none", 1: "slow", 2: "error"}
            chaos_str = chaos_map.get(int(chaos_val), "unknown")

            # Query OPA for policy compliance
            infra_input = {
                "disk_free_gb": round(psutil.disk_usage("/").free / (1024 ** 3), 2),
                "cpu_load": round(psutil.getloadavg()[0], 2),
                "memory_percent": round(psutil.virtual_memory().percent, 2),
                "check": "status"
            }
            canary_input = {
                "error_rate": round(error_rate, 4),
                "p99_latency_ms": round(p99_latency_ms, 2),
                "check": "status"
            }

            infra_allow, infra_violations, infra_err = query_opa("swiftdeploy/infrastructure", infra_input)
            canary_allow, canary_violations, canary_err = query_opa("swiftdeploy/canary", canary_input)

            # Build history record
            record = {
                "timestamp": timestamp,
                "mode": mode_str,
                "chaos": chaos_str,
                "error_rate": round(error_rate, 4),
                "p99_latency_ms": round(p99_latency_ms, 2),
                "uptime_seconds": round(uptime, 2),
                "policy": {
                    "infrastructure": {
                        "allow": infra_allow,
                        "violations": infra_violations
                    },
                    "canary": {
                        "allow": canary_allow,
                        "violations": canary_violations
                    }
                }
            }

            # Append to history.jsonl
            with open(history_file, "a") as f:
                f.write(json.dumps(record) + "\n")

            # Clear screen and print dashboard
            os.system("clear")
            print("╔══════════════════════════════════════════════════════╗")
            print("║           SwiftDeploy Status Dashboard               ║")
            print("╚══════════════════════════════════════════════════════╝")
            print(f"  Time:        {timestamp}")
            print(f"  Mode:        {mode_str}")
            print(f"  Chaos:       {chaos_str}")
            print(f"  Uptime:      {round(uptime, 1)}s")
            print()
            print("── Metrics ─────────────────────────────────────────────")
            print(f"  Error Rate:  {error_rate * 100:.2f}%")
            print(f"  P99 Latency: {p99_latency_ms:.1f}ms")
            print()
            print("── Policy Compliance ────────────────────────────────────")

            if infra_err:
                print(f"  Infrastructure: ⚠️  {infra_err}")
            elif infra_allow:
                print("  Infrastructure: ✅ PASSING")
            else:
                print("  Infrastructure: ❌ FAILING")
                for v in infra_violations:
                    print(f"    • {v}")

            if canary_err:
                print(f"  Canary Safety:  ⚠️  {canary_err}")
            elif canary_allow:
                print("  Canary Safety:  ✅ PASSING")
            else:
                print("  Canary Safety:  ❌ FAILING")
                for v in canary_violations:
                    print(f"    • {v}")

            print()
            print("── Audit ────────────────────────────────────────────────")
            print(f"  History:     {history_file}")
            print()
            print("  Refreshing every 5s — Ctrl+C to exit")

            time.sleep(5)

    except KeyboardInterrupt:
        print("\n\n👋 Status dashboard stopped.")

def cmd_audit():
    """
    Parse history.jsonl and generate audit_report.md.
    Includes a timeline of mode changes and chaos injections,
    and a violations section for any failed policy checks.
    """
    history_file = ROOT / "history.jsonl"
    report_file = ROOT / "audit_report.md"

    if not history_file.exists():
        print("❌ No history.jsonl found — run 'swiftdeploy status' first")
        sys.exit(1)

    records = []
    with open(history_file) as f:
        for line in f:
            line = line.strip()
            if line:
                try:
                    records.append(json.loads(line))
                except json.JSONDecodeError:
                    continue

    if not records:
        print("❌ history.jsonl is empty")
        sys.exit(1)

    # ── Build timeline of mode changes and chaos injections ──────────────────
    timeline = []
    prev_mode = None
    prev_chaos = None

    for r in records:
        mode = r.get("mode", "unknown")
        chaos = r.get("chaos", "none")
        ts = r.get("timestamp", "unknown")

        if mode != prev_mode:
            timeline.append({
                "timestamp": ts,
                "event": f"Mode changed to **{mode}**",
                "mode": mode,
                "chaos": chaos
            })
            prev_mode = mode

        if chaos != prev_chaos:
            if chaos != "none":
                timeline.append({
                    "timestamp": ts,
                    "event": f"Chaos injected: **{chaos}**",
                    "mode": mode,
                    "chaos": chaos
                })
            else:
                timeline.append({
                    "timestamp": ts,
                    "event": "Chaos recovered",
                    "mode": mode,
                    "chaos": chaos
                })
            prev_chaos = chaos

    # ── Collect violations ───────────────────────────────────────────────────
    violations = []
    for r in records:
        ts = r.get("timestamp", "unknown")
        policy = r.get("policy", {})

        for domain, result in policy.items():
            if not result.get("allow", True):
                for msg in result.get("violations", []):
                    violations.append({
                        "timestamp": ts,
                        "domain": domain,
                        "violation": msg,
                        "mode": r.get("mode", "unknown"),
                        "chaos": r.get("chaos", "none")
                    })

    # ── Write report ─────────────────────────────────────────────────────────
    first = records[0]
    last = records[-1]

    with open(report_file, "w") as f:
        f.write("# SwiftDeploy Audit Report\n\n")
        f.write(f"**Generated:** {time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime())}  \n")
        f.write(f"**Period:** {first['timestamp']} → {last['timestamp']}  \n")
        f.write(f"**Total scrapes:** {len(records)}  \n\n")
        f.write("---\n\n")

        # Timeline section
        f.write("## Timeline\n\n")
        if timeline:
            f.write("| Timestamp | Event | Mode | Chaos |\n")
            f.write("|---|---|---|---|\n")
            for t in timeline:
                f.write(f"| {t['timestamp']} | {t['event']} | {t['mode']} | {t['chaos']} |\n")
        else:
            f.write("_No mode changes or chaos events recorded._\n")

        f.write("\n---\n\n")

        # Violations section
        f.write("## Policy Violations\n\n")
        if violations:
            f.write("| Timestamp | Domain | Violation | Mode | Chaos |\n")
            f.write("|---|---|---|---|---|\n")
            for v in violations:
                f.write(f"| {v['timestamp']} | {v['domain']} | {v['violation']} | {v['mode']} | {v['chaos']} |\n")
        else:
            f.write("_No policy violations recorded._\n")

        f.write("\n---\n\n")

        # Summary section
        f.write("## Summary\n\n")
        total_violations = len(violations)
        canary_scrapes = sum(1 for r in records if r.get("mode") == "canary")
        stable_scrapes = sum(1 for r in records if r.get("mode") == "stable")
        chaos_scrapes = sum(1 for r in records if r.get("chaos") != "none")

        f.write(f"| Metric | Value |\n")
        f.write(f"|---|---|\n")
        f.write(f"| Total scrapes | {len(records)} |\n")
        f.write(f"| Stable scrapes | {stable_scrapes} |\n")
        f.write(f"| Canary scrapes | {canary_scrapes} |\n")
        f.write(f"| Chaos scrapes | {chaos_scrapes} |\n")
        f.write(f"| Total violations | {total_violations} |\n")

    print(f"✅ Audit report generated: {report_file}")


def main():
    args = sys.argv[1:]

    if not args:
        print("Usage: swiftdeploy [init|validate|deploy|promote|teardown]")
        sys.exit(1)

    command = args[0]

    if command == "init":
        cmd_init()

    elif command == "validate":
        cmd_validate()

    elif command == "deploy":
        cmd_deploy()

    elif command == "promote":
        if len(args) < 2:
            print("❌ Usage: swiftdeploy promote [stable|canary]")
            sys.exit(1)
        cmd_promote(args[1])

    elif command == "teardown":
        clean = "--clean" in args
        cmd_teardown(clean)

    elif command == "status":
        cmd_status()

    elif command == "audit":
        cmd_audit()

    else:
        print(f"❌ Unknown command: {command}")
        print("Usage: swiftdeploy [init|validate|deploy|promote|teardown]")
        sys.exit(1)


if __name__ == "__main__":
    main()
