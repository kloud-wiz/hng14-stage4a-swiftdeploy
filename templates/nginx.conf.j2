log_format custom '$time_iso8601 | $status | ${request_time}s | $upstream_addr | $request';

server {
    listen {{ nginx.port }};

    access_log /var/log/nginx/access.log custom;
    error_log /var/log/nginx/error.log warn;

    # Pass requests to the app service
    location / {
        proxy_pass http://app:{{ services.port }};

        proxy_connect_timeout {{ nginx.proxy_timeout }}s;
        proxy_send_timeout    {{ nginx.proxy_timeout }}s;
        proxy_read_timeout    {{ nginx.proxy_timeout }}s;

        # Standard proxy headers
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Forward X-Mode header from upstream response to client
        proxy_pass_header X-Mode;

        # Tag all responses with swiftdeploy
        add_header X-Deployed-By swiftdeploy always;
    }

    # JSON error responses for gateway errors
    error_page 502 /error_502.json;
    error_page 503 /error_503.json;
    error_page 504 /error_504.json;

    location = /error_502.json {
        internal;
        default_type application/json;
        return 502 '{"error":"Bad Gateway","code":502,"service":"{{ services.image }}","contact":"admin@swiftdeploy.local"}';
    }

    location = /error_503.json {
        internal;
        default_type application/json;
        return 503 '{"error":"Service Unavailable","code":503,"service":"{{ services.image }}","contact":"admin@swiftdeploy.local"}';
    }

    location = /error_504.json {
        internal;
        default_type application/json;
        return 504 '{"error":"Gateway Timeout","code":504,"service":"{{ services.image }}","contact":"admin@swiftdeploy.local"}';
    }
}
