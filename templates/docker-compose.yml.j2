services:
  app:
    image: {{ services.image }}
    container_name: swiftdeploy-app
    environment:
      - MODE={{ services.mode }}
      - APP_VERSION={{ services.version }}
      - APP_PORT={{ services.port }}
    expose:
      - "{{ services.port }}"
    networks:
      - {{ network.name }}
    volumes:
      - {{ volumes.logs }}:/app/logs
    restart: {{ services.restart_policy }}
    cap_drop:
      - ALL
    user: "1000"
    healthcheck:
      test: ["CMD", "python", "-c", "import urllib.request; urllib.request.urlopen('http://localhost:{{ services.port }}/healthz')"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s

  nginx:
    image: {{ nginx.image }}
    container_name: swiftdeploy-nginx
    ports:
      - "{{ nginx.port }}:80"
    volumes:
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
    depends_on:
      app:
        condition: service_healthy
    networks:
      - {{ network.name }}
    restart: {{ services.restart_policy }}
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
      - SETUID
      - SETGID
      - CHOWN
      - DAC_OVERRIDE
      - FOWNER

  opa:
    image: openpolicyagent/opa:latest
    container_name: swiftdeploy-opa
    ports:
      - "127.0.0.1:{{ opa.port }}:{{ opa.port }}"
    command:
      - "run"
      - "--server"
      - "--addr=0.0.0.0:8181"
      - "--log-level=error"
      - "/policies"
    volumes:
      - ./policies:/policies:ro
    networks:
      - {{ network.name }}
    restart: {{ services.restart_policy }}
    cap_drop:
      - ALL

networks:
  {{ network.name }}:
    driver: {{ network.driver_type }}

volumes:
  {{ volumes.logs }}:
